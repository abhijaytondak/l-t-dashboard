{
  "name": "lt-verify",
  "private": true,
  "version": "0.2.0",
  "description": "Bill-verification monorepo: Express extraction/engine API + Next.js reviewer console.",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:server": "yarn workspace server dev",
    "dev:web": "yarn workspace @lt/web dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
