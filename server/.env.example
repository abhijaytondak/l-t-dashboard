# Copy to .env (here or at the repo root) and fill in. NEVER commit .env.
# Keys are read on the server only; never sent to the client.

# Which LLM reads/classifies the bill: gemini | anthropic | openai
LLM_PROVIDER=gemini

# Provide only the key for the provider you selected above.
GEMINI_API_KEY=          # https://aistudio.google.com/apikey (free tier)
ANTHROPIC_API_KEY=       # https://console.anthropic.com (paid API credits)
OPENAI_API_KEY=          # https://platform.openai.com/api-keys

# Optional model overrides (defaults shown)
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# PostgreSQL connection string. Required.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ltverify

# Optional
PORT=3001
# PGSSL=false
