# Copy this file to .env at the repo root and fill in the values.
# Keys are read by the server only — never sent to the client.
# NEVER commit your real .env (it is gitignored).

# ---- Which LLM reads/classifies the bill --------------------------------
# One of: gemini | anthropic | openai
# You only need the key for the provider you select here.
LLM_PROVIDER=gemini

# ---- Google Gemini (free tier) ------------------------------------------
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ---- Anthropic Claude (paid API credits; not your Claude.ai subscription) -
# Key: https://console.anthropic.com  → Billing (add credit) → API Keys
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- OpenAI -------------------------------------------------------------
# Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ---- Database -----------------------------------------------------------
# PostgreSQL connection string. The server creates and seeds the tables on
# startup. Point this at any reachable Postgres instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ltverify
